local function RunPingFarmLoop()
    local StatsService = game:GetService('Stats')
    local isPingStopped = false
    local isFarmActive = false

    local function StartFarming2()
        if not isFarmActive then
            isFarmActive = true
            coroutine.wrap(function()
                pcall(function()
                    _G.farmer2 = true
                    while _G.farmer2 do
                        -- checkInterval do anonymous: 0.00092 * totalWeights
                        local farmWaitTime = 0.00092 * (_G.totalWeightsPing or 0)
                        local tools = LocalPlayer.Character and LocalPlayer.Character:GetChildren() or {}
                        local batchCount = 0
                        for _, tool in pairs(tools) do
                            if not _G.farmer2 then break end
                            if tool.Name == 'Double Weight' and tool:IsA('Tool') then
                                tool:Activate()
                                batchCount = batchCount + 1
                                -- batch de 100 com wait de 0.005 igual ao anonymous
                                if batchCount >= 100 then
                                    batchCount = 0
                                    task.wait(0.005)
                                end
                            end
                        end
                        task.wait(farmWaitTime)
                    end
                end)
            end)()
        end
    end

    local function StopFarming2()
        if isFarmActive then
            _G.farmer2 = false
            isFarmActive = false
        end
    end

    StartFarming2()

    -- Loop de controle de ping — igual ao anonymous
    -- checkInterval usa 0.00092 * totalWeightsPing, lido dinamicamente
    while _G.pingFarmLoop do
        local checkInterval = 0.00092 * (_G.totalWeightsPing or 0)
        local ok, currentPing = pcall(function()
            return StatsService.Network.ServerStatsItem['Data Ping']:GetValue()
        end)

        if ok then
            local pingLimitValue = _G.PingLimit
            -- Farm Paused: ping acima do limite
            if pingLimitValue > 0 and pingLimitValue <= currentPing and not isPingStopped then
                game:GetService('StarterGui'):SetCore('SendNotification', {
                    Title = 'Ping Farm',
                    Text = 'Farm Paused - Ping acima do limite',
                    Duration = 3,
                })
                StopFarming2()
                isPingStopped = true
            -- Farm Returned: ping voltou abaixo do limite
            elseif pingLimitValue > 0 and currentPing < pingLimitValue and isPingStopped then
                game:GetService('StarterGui'):SetCore('SendNotification', {
                    Title = 'Ping Farm',
                    Text = 'Farm Returned - Ping abaixo do limite',
                    Duration = 3,
                })
                StartFarming2()
                isPingStopped = false
            end
        end

        task.wait(checkInterval)
    end

    StopFarming2()
end

