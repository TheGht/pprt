coroutine.wrap(function()
    local startTime = nil

    local function FormatTime(t)
        return string.format('%02i', t)
    end
    local function ConvertToDHMS(seconds)
        local s = math.floor(seconds)
        local minutes = math.floor(s / 60)
        local remainingSeconds = s % 60
        local hours = math.floor(minutes / 60)
        local remainingMinutes = minutes % 60
        local days = math.floor(hours / 24)
        local remainingHours = hours % 24
        return FormatTime(days) .. ':' .. FormatTime(remainingHours) .. ':' .. FormatTime(remainingMinutes) .. ':' .. FormatTime(remainingSeconds)
    end

    while true do
        if _G.farmer or _G.farmer2 then
            if not startTime then startTime = os.time() end
            local elapsedTime = os.time() - startTime
            Spw_2.Text = 'Time Farming: ' .. ConvertToDHMS(elapsedTime)
