-- ============================================================
-- FORMAT FUNCTIONS
-- ============================================================
local NumberSuffixes = {'', 'K', 'M', 'B', 'T'}

local function FormatNumber(number, decimalPlaces)
    local exponent = math.floor(math.log(math.max(1, math.abs(number)), 1000))
    local suffix = NumberSuffixes[1 + exponent] or 'e+' .. exponent
    local scaledNumber = math.floor(number * (10 ^ decimalPlaces / 1000 ^ exponent)) / 10 ^ decimalPlaces
    return ('%.' .. decimalPlaces .. 'f%s'):format(scaledNumber, suffix)
end

local function FormatStrength(strengthValue)
    local formattedValue
    if strengthValue >= 1000000000000 then
        formattedValue = string.format('%.2fT', math.floor(strengthValue / 10000000000) / 100)
    elseif strengthValue >= 1000000000 then
        formattedValue = string.format('%.2fB', math.floor(strengthValue / 10000000) / 100)
    elseif strengthValue >= 1000000 then
        formattedValue = string.format('%.2fM', math.floor(strengthValue / 10000) / 100)
    elseif strengthValue >= 1000 then
        formattedValue = string.format('%.2fK', math.floor(strengthValue / 10) / 100)
    else
        formattedValue = tostring(strengthValue)
    end
    return formattedValue
end

